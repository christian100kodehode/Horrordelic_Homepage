{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/.+\\.(js|css|png|jpg|jpeg|gif|svg|ico|webp|avif|json|webmanifest|txt|xml)$",
      "destination": "/$0"
    },

    { "source": "/api/:path*", "destination": "/api/:path*" },

    { "source": "/:path*", "destination": "/api/simple-og" }
  ]
}
