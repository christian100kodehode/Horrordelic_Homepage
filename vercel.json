{
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/.+\\.(js|css|png|jpg|jpeg|gif|svg|webp|ico|json|webmanifest|txt|xml)$",
      "destination": "/$0"
    },

    {
      "source": "/:path*",
      "destination": "/api/og"
    }
  ]
}
