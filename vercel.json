{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/Release/:path*",
      "destination": "/Releases/:path*"
    },

    {
      "source": "/.+\\.(js|css|png|jpg|jpeg|gif|svg|webp|ico|json|webmanifest|txt|xml|woff2?|eot|ttf|otf)$",
      "destination": "/$0"
    },

    {
      "source": "/Artist/:path*",
      "destination": "/api/simple-og"
    }
  ]
}
