{
  "rewrites": [
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    },
    {
      "source": "/.+\\.(js|css|png|jpg|jpeg|gif|svg|webp|ico|json|webmanifest|txt|xml)$",
      "destination": "/$0"
    },

    {
      "source": "/:path*",
      "destination": "/api/simple-og"
    }
  ]
}
