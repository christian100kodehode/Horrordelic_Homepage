{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node", // ← important for resolving 'fs', 'path'
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"] // ← this line tells TS to include @types/node
  },
  "include": ["**/*.ts", "**/*.tsx", "api/**/*.ts"], // make sure api/ is included
  "exclude": ["node_modules", "dist"]
}
